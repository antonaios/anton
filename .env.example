# ANTON environment configuration - copy to `.env` and fill in.
# NO real keys belong in this file or in `.env.example`.

# --- Core paths ---
AGENTIC_VAULT=<absolute-path-to-your-vault>
CLAUDE_PROJECTS_DIR=<absolute-path-to-claude-projects-dir>
AGENTIC_SESSIONS_DIR=<absolute-path-to-sessions-dir>
AGENTIC_DASHBOARD_DIST=<absolute-path-to-dashboard/dist>

# --- Bridge HTTP server ---
AGENTIC_API_HOST=127.0.0.1
AGENTIC_API_PORT=8765
AGENTIC_ALLOW_PUBLIC_BIND=0
AGENTIC_DASHBOARD_MODE=production

# --- Plan tier / routing (bridge | enterprise) ---
AGENTIC_PLAN_TIER=bridge

# --- Cost caps ---
AGENTIC_CAP_5H_TOKENS=
AGENTIC_CAP_WEEKLY_TOKENS=
AGENTIC_CAP_ROUTINES_RUNS=

# --- Search providers (sector news / deal tracker / earnings) ---
AGENTIC_SEARCH_PROVIDER=firecrawl
FIRECRAWL_API_KEY=<your-firecrawl-key>
TAVILY_API_KEY=<your-tavily-key>
TAVILY_API_KEYS=<comma-separated-tavily-keys-optional>
MARKETS_FORCE_STUB=0

# --- Cloud LLM fallback (optional) ---
ANTHROPIC_API_KEY=<your-anthropic-key>

# --- Crew lane tuning (optional) ---
ANTON_CREW_TIMEOUT_S=
ANTON_CREW_EVENT_TTL_S=
ANTON_CREW_HUMAN_REPLY_TIMEOUT_S=

# --- Databases (optional overrides; default to local paths) ---
AGENTIC_SENSITIVITY_OVERRIDES_DB=
AGENTIC_SUSPENSIONS_DB=
